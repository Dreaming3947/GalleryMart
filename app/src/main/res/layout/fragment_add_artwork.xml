<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/spacing_medium"
        android:paddingVertical="@dimen/spacing_medium">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="@dimen/button_height"
            android:layout_height="@dimen/button_height"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/back"
            android:src="@android:drawable/ic_media_previous"
            app:tint="@color/black" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:layout_toStartOf="@id/btnClose"
            android:layout_toEndOf="@id/btnBack"
            android:gravity="center"
            android:letterSpacing="0.2"
            android:text="@string/studio_creative"
            android:textColor="@color/stone_900"
            android:textSize="@dimen/text_caption"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="@dimen/button_height"
            android:layout_height="@dimen/button_height"
            android:layout_alignParentEnd="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/close"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="@color/black" />
    </RelativeLayout>

    <!-- Step Indicators -->
    <LinearLayout
        android:id="@+id/stepIndicatorContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_xlarge"
        android:paddingVertical="@dimen/spacing_medium">

        <View
            android:id="@+id/step1Indicator"
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:layout_weight="1"
            android:background="@color/stone_900" />

        <View
            android:layout_width="16dp"
            android:layout_height="0dp" />

        <View
            android:id="@+id/step2Indicator"
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:layout_weight="1"
            android:background="@color/stone_100" />

        <View
            android:layout_width="16dp"
            android:layout_height="0dp" />

        <View
            android:id="@+id/step3Indicator"
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:layout_weight="1"
            android:background="@color/stone_100" />

        <View
            android:layout_width="16dp"
            android:layout_height="0dp" />

        <View
            android:id="@+id/step4Indicator"
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:layout_weight="1"
            android:background="@color/stone_100" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/stepContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="@dimen/spacing_large">

        <!-- Step 1: Upload (Mocking with visibility) -->
        <ScrollView
            android:id="@+id/layoutStep1"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/display_artwork"
                    android:textColor="@color/stone_900"
                    android:textSize="@dimen/text_display"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_small"
                    android:text="@string/first_photo_desc"
                    android:textColor="@color/stone_800"
                    android:textSize="12sp" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xlarge"
                    android:columnCount="2"
                    android:rowCount="2">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnAddImage"
                        android:layout_width="0dp"
                        android:layout_height="160dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="6dp"
                        app:cardBackgroundColor="@color/stone_50"
                        app:cardCornerRadius="@dimen/card_corner_radius_xlarge"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/stone_100"
                        app:strokeWidth="2dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:drawablePadding="@dimen/spacing_small"
                            android:gravity="center"
                            android:text="@string/add_photo"
                            android:textColor="@color/primary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            app:drawableTint="@color/stone_800"
                            app:drawableTopCompat="@android:drawable/ic_menu_camera" />
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cvStep1Preview"
                        android:layout_width="0dp"
                        android:layout_height="160dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="6dp"
                        android:visibility="gone"
                        app:cardCornerRadius="32dp"
                        app:cardElevation="0dp">

                        <ImageView
                            android:id="@+id/ivStep1Preview"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/display_artwork"
                            android:scaleType="centerCrop" />
                    </com.google.android.material.card.MaterialCardView>
                </GridLayout>
            </LinearLayout>
        </ScrollView>

        <!-- Step 2: Info (Mocking) -->
        <ScrollView
            android:id="@+id/layoutStep2"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/artwork_title"
                    android:textColor="@color/stone_600"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_small"
                    android:autofillHints="name"
                    android:background="@drawable/bg_input_field"
                    android:hint="@string/hint_title"
                    android:inputType="textCapWords"
                    android:padding="@dimen/spacing_medium"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/category"
                    android:textColor="@color/stone_600"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/cgCategory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:singleSelection="true">
                    <!-- Chips will be added dynamically -->
                </com.google.android.material.chip.ChipGroup>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/artwork_story"
                    android:textColor="@color/stone_600"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etDescription"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:layout_marginTop="@dimen/spacing_small"
                    android:autofillHints="none"
                    android:background="@drawable/bg_input_field"
                    android:gravity="top"
                    android:hint="@string/hint_description"
                    android:inputType="textMultiLine"
                    android:padding="@dimen/spacing_medium"
                    android:textSize="@dimen/text_body" />
            </LinearLayout>
        </ScrollView>

        <!-- Step 3: Pricing (Added) -->
        <ScrollView
            android:id="@+id/layoutStep3"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/listing_price"
                    android:textColor="@color/stone_600"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etPrice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_small"
                    android:autofillHints="none"
                    android:background="@drawable/bg_input_field"
                    android:hint="@string/hint_price"
                    android:inputType="numberDecimal"
                    android:padding="@dimen/spacing_medium"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/dimensions"
                    android:textColor="@color/stone_600"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etDimensions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_small"
                    android:autofillHints="none"
                    android:background="@drawable/bg_input_field"
                    android:hint="@string/hint_dimensions"
                    android:inputType="text"
                    android:padding="@dimen/spacing_medium"
                    android:textSize="@dimen/text_body" />
            </LinearLayout>
        </ScrollView>

        <!-- Step 4: Review (Added) -->
        <ScrollView
            android:id="@+id/layoutStep4"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="240dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp">

                    <ImageView
                        android:id="@+id/ivPreview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/display_artwork"
                        android:scaleType="centerCrop"
                        android:src="@color/stone_100" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tvReviewTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/preview_title"
                    android:textColor="@color/stone_900"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvReviewPrice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/preview_price"
                    android:textColor="@color/stone_600"
                    android:textSize="16sp" />
            </LinearLayout>
        </ScrollView>
    </FrameLayout>

    <!-- Footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_large">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnPrev"
            android:layout_width="@dimen/button_height_large"
            android:layout_height="@dimen/button_height_large"
            android:visibility="gone"
            app:cardBackgroundColor="@color/stone_100"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <ImageView
                android:layout_width="@dimen/icon_medium"
                android:layout_height="@dimen/icon_medium"
                android:layout_gravity="center"
                android:contentDescription="@string/back"
                android:src="@android:drawable/ic_media_previous"
                app:tint="@color/stone_900" />
        </com.google.android.material.card.MaterialCardView>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNext"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/button_height_large"
            android:minWidth="120dp"
            android:backgroundTint="@color/stone_900"
            android:letterSpacing="0.2"
            android:text="@string/next"
            android:textColor="@color/white"
            android:textSize="@dimen/text_caption"
            android:textStyle="bold"
            app:cornerRadius="20dp"
            app:icon="@android:drawable/ic_media_next"
            app:iconGravity="textEnd" />
    </LinearLayout>

</LinearLayout>
