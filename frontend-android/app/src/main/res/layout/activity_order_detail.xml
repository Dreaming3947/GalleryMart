<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_off_white">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottomContainer"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_normal">

            <!-- Top Header Card (Dark) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_normal"
                app:cardBackgroundColor="@color/black"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_normal">

                    <TextView
                        android:id="@+id/tvOrderDetailId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đơn hàng #ORD-12345"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvOrderDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_small"
                        android:text="Ngày đặt: 20/10/2023"
                        android:textColor="@color/white"
                        android:alpha="0.7" />

                    <TextView
                        android:id="@+id/tvEstimatedDelivery"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dự kiến giao: 25/10/2023"
                        android:textColor="@color/white"
                        android:alpha="0.7" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Timeline Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_normal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_normal"
                        android:text="Hành trình đơn hàng"
                        android:textColor="@color/black"
                        android:textStyle="bold" />

                    <!-- Step 1: Ordered -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <View
                            android:id="@+id/dot1"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="@drawable/shape_dot_black"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <View
                            android:id="@+id/line1"
                            android:layout_width="2dp"
                            android:layout_height="40dp"
                            android:background="@color/black"
                            app:layout_constraintEnd_toEndOf="@id/dot1"
                            app:layout_constraintStart_toStartOf="@id/dot1"
                            app:layout_constraintTop_toBottomOf="@id/dot1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_normal"
                            android:text="Đã đặt hàng"
                            android:textColor="@color/black"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="@id/dot1"
                            app:layout_constraintStart_toEndOf="@id/dot1"
                            app:layout_constraintTop_toTopOf="@id/dot1" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Step 2: Confirmed -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <View
                            android:id="@+id/dot2"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="@drawable/shape_dot_black"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <View
                            android:id="@+id/line2"
                            android:layout_width="2dp"
                            android:layout_height="40dp"
                            android:background="@color/divider"
                            app:layout_constraintEnd_toEndOf="@id/dot2"
                            app:layout_constraintStart_toStartOf="@id/dot2"
                            app:layout_constraintTop_toBottomOf="@id/dot2" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_normal"
                            android:text="Đã xác nhận"
                            android:textColor="@color/black"
                            app:layout_constraintBottom_toBottomOf="@id/dot2"
                            app:layout_constraintStart_toEndOf="@id/dot2"
                            app:layout_constraintTop_toTopOf="@id/dot2" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Step 3: Delivering -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <View
                            android:id="@+id/dot3"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="@drawable/shape_dot_gray"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_normal"
                            android:text="Đang giao hàng"
                            android:textColor="@color/text_secondary"
                            app:layout_constraintBottom_toBottomOf="@id/dot3"
                            app:layout_constraintStart_toEndOf="@id/dot3"
                            app:layout_constraintTop_toTopOf="@id/dot3" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/bottomContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="8dp"
        android:padding="@dimen/spacing_normal"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCallShipper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/black"
            android:text="Gọi Shipper"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app:cornerRadius="@dimen/button_corner_radius" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
