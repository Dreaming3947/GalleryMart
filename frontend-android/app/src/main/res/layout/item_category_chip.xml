<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginEnd="12dp"
    android:background="@drawable/bg_chip_unselected"
    android:gravity="center_vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="10dp">

    <ImageView
        android:id="@+id/chipIcon"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_marginEnd="8dp"
        android:src="@drawable/ic_self_improvement"
        app:tint="@color/gm_text_primary" />

    <TextView
        android:id="@+id/chipName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Yên bình"
        android:textColor="@color/gm_text_primary"
        android:textSize="14sp"
        android:textStyle="bold" />
</LinearLayout>
