<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gm_bg"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingBottom="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_menu"
                app:tint="#9EA0A2" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="CURATOR"
                android:textColor="#101213"
                android:textSize="31px"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_shopping_bag"
                app:tint="#9EA0A2" />
        </RelativeLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="420dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_hero_card"
            android:clipToOutline="true">

            <ImageView
                android:id="@+id/heroImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:scaleType="centerCrop" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Discover Unique Artworks"
                    android:textColor="#FFFFFF"
                    android:textSize="33px" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnExploreGallery"
                        android:layout_width="0dp"
                        android:layout_height="68dp"
                        android:layout_marginEnd="10dp"
                        android:layout_weight="1"
                        android:text="EXPLORE&#10;GALLERY"
                        android:textColor="#111213"
                        android:textSize="14sp"
                        app:backgroundTint="#F3F3F3"
                        app:cornerRadius="34dp"
                        app:strokeWidth="0dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSellArt"
                        android:layout_width="0dp"
                        android:layout_height="68dp"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:text="SELL&#10;ART"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        app:backgroundTint="#111213"
                        app:cornerRadius="34dp"
                        app:strokeColor="#66FFFFFF"
                        app:strokeWidth="1dp" />
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_search_bar"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="21dp"
                android:layout_height="21dp"
                android:src="@drawable/ic_search"
                app:tint="#3A3D3F" />

            <EditText
                android:id="@+id/searchInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Search artists, styles, or artworks"
                android:inputType="text"
                android:textColor="#101213"
                android:textColorHint="#9EA0A2"
                android:textSize="31px" />

            <FrameLayout
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_filter_circle"
                android:padding="7dp">

                <ImageView
                    android:id="@+id/btnHomeTune"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_tune"
                    app:tint="#16181A" />
            </FrameLayout>
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_chip_selected"
                    android:paddingHorizontal="22dp"
                    android:paddingVertical="11dp"
                    android:text="#All"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:paddingHorizontal="22dp"
                    android:paddingVertical="11dp"
                    android:text="#Oil painting"
                    android:textColor="#424648"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:paddingHorizontal="22dp"
                    android:paddingVertical="11dp"
                    android:text="#Landscape"
                    android:textColor="#424648"
                    android:textSize="14sp" />
            </LinearLayout>
        </HorizontalScrollView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:text="Featured Artworks"
            android:textColor="#232526"
            android:textSize="34px" />

        <ProgressBar
            android:id="@+id/loadingView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/errorView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#B00020"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/featuredRecycler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_sell_panel"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingVertical="26dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Start selling your art today"
                android:textColor="#FFFFFF"
                android:textSize="31px" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="Join our curated community of artists and collectors. Showcase your unique perspective to the world."
                android:textColor="#D9DEE3"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUploadArtwork"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="22dp"
                android:text="UPLOAD ARTWORK"
                android:textColor="#121416"
                android:textSize="14sp"
                app:backgroundTint="#F3F3F3"
                app:cornerRadius="28dp"
                app:strokeWidth="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBecomeSeller"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:text="BECOME A SELLER"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                app:backgroundTint="#00000000"
                app:cornerRadius="28dp"
                app:strokeColor="#42FFFFFF"
                app:strokeWidth="1dp" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>

